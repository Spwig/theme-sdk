{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Theme Package Manifest Schema",
  "description": "Schema for Spwig v2.0 theme package manifests",
  "type": "object",
  "required": [
    "name",
    "version",
    "display_name",
    "description",
    "author"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 2,
      "maxLength": 50,
      "description": "Theme identifier (lowercase, alphanumeric with hyphens)"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Human-readable theme name"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000,
      "description": "Theme description for marketplace listing"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Theme author/vendor name"
    },
    "sdk_version": {
      "type": "string",
      "description": "SDK version used to create this theme (e.g., '2.0')"
    },
    "license": {
      "type": "string",
      "enum": ["MIT", "Apache-2.0", "GPL-3.0", "Proprietary"],
      "default": "Proprietary",
      "description": "Theme license type"
    },
    "preview_image": {
      "type": "string",
      "pattern": "^.+\\.(png|jpg|jpeg|webp)$",
      "description": "Theme preview image filename (recommended: 600x800px, max 5MB)"
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "pattern": "^.+\\.(png|jpg|jpeg|webp)$",
            "description": "Screenshot file path relative to theme root"
          },
          "title": {
            "type": "string",
            "maxLength": 100,
            "description": "Display title for the screenshot (e.g., 'Home', 'Mobile — Product')"
          }
        },
        "additionalProperties": false
      },
      "maxItems": 12,
      "description": "Screenshot entries for theme showcase (desktop: 1440x900, mobile: 780x1688)"
    },
    "videos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "pattern": "^.+\\.(webm|mp4)$",
            "description": "Video file path relative to theme root"
          },
          "title": {
            "type": "string",
            "maxLength": 100,
            "description": "Display title for the video"
          }
        },
        "additionalProperties": false
      },
      "maxItems": 2,
      "description": "Video entries for theme showcase (max 20MB each, webm or mp4)"
    },
    "demo_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to live demo of theme"
    },
    "documentation_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to theme documentation"
    },
    "support_url": {
      "type": "string",
      "format": "uri",
      "description": "URL for theme support"
    },
    "tags": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$",
        "maxLength": 30
      },
      "description": "Searchable tags for theme marketplace"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "fashion",
          "electronics",
          "home-garden",
          "sports",
          "beauty",
          "food-beverage",
          "books",
          "toys",
          "jewelry",
          "automotive",
          "general"
        ]
      },
      "description": "Theme categories for marketplace organization"
    },
    "color_schemes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "colors"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Color scheme name (e.g., 'Light', 'Dark')"
          },
          "colors": {
            "type": "object",
            "properties": {
              "primary": {
                "type": "string",
                "pattern": "^#[0-9A-Fa-f]{6}$"
              },
              "secondary": {
                "type": "string",
                "pattern": "^#[0-9A-Fa-f]{6}$"
              },
              "accent": {
                "type": "string",
                "pattern": "^#[0-9A-Fa-f]{6}$"
              },
              "background": {
                "type": "string",
                "pattern": "^#[0-9A-Fa-f]{6}$"
              },
              "text": {
                "type": "string",
                "pattern": "^#[0-9A-Fa-f]{6}$"
              }
            }
          }
        }
      },
      "description": "Pre-defined color schemes for theme"
    },
    "features": {
      "type": "object",
      "properties": {
        "responsive": {
          "type": "boolean",
          "default": true,
          "description": "Whether the theme supports responsive design"
        },
        "mobile_first": {
          "type": "boolean",
          "default": true,
          "description": "Whether the theme uses mobile-first design approach"
        },
        "dark_mode": {
          "type": "boolean",
          "default": false,
          "description": "Whether this theme provides dark mode tokens. Inherently dark themes should set this to false."
        },
        "rtl_support": {
          "type": "boolean",
          "default": false,
          "description": "Whether the theme supports right-to-left languages"
        },
        "accessibility": {
          "type": "string",
          "description": "Accessibility standard compliance (e.g., 'WCAG 2.1 AA')"
        }
      },
      "additionalProperties": true,
      "description": "Theme feature flags indicating capabilities"
    },
    "min_platform_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "description": "Minimum platform version required"
    },
    "max_platform_version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "description": "Maximum platform version supported"
    },
    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["version", "date", "changes"],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
          },
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "changes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        }
      },
      "description": "Version history and changes"
    },
    "total_size_bytes": {
      "type": "integer",
      "description": "Total package size in bytes (added during packaging)"
    },
    "file_count": {
      "type": "integer",
      "description": "Total number of files (added during packaging)"
    },
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA256 checksum of package contents (added during packaging)"
    },
    "author_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the theme author's website (displayed in marketplace)"
    },
    "design_tokens": {
      "type": "string",
      "description": "Path to the design tokens file (e.g., 'tokens.json')"
    },
    "assets": {
      "type": "object",
      "properties": {
        "css": {
          "type": "array",
          "items": { "type": "string" },
          "description": "CSS file paths included in the theme"
        },
        "js": {
          "type": "array",
          "items": { "type": "string" },
          "description": "JavaScript file paths included in the theme"
        },
        "critical_css": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Critical CSS paths keyed by page type (e.g., 'home', 'product')"
        }
      },
      "additionalProperties": true,
      "description": "Theme asset file references (CSS, JS, critical CSS)"
    },
    "bundled_components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name", "path"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["header", "footer", "section", "widget"],
            "description": "Component type"
          },
          "name": {
            "type": "string",
            "description": "Component identifier"
          },
          "path": {
            "type": "string",
            "description": "Path to the component within the theme package"
          }
        }
      },
      "description": "Components bundled with the theme (headers, footers, sections)"
    },
    "page_schemas": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Page schema paths keyed by page type"
        },
        {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of page schema file paths (legacy format)"
        }
      ],
      "description": "Page layout schema definitions (optional, legacy feature)"
    },
    "external_dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "cdn": { "type": "string", "format": "uri" },
          "integrity": { "type": "string" }
        }
      },
      "description": "External dependencies required by the theme (e.g., icon libraries, fonts)"
    },
    "deprecated": {
      "type": "boolean",
      "default": false,
      "description": "Whether this theme version is deprecated"
    },
    "deprecation_message": {
      "type": "string",
      "maxLength": 500,
      "description": "Message explaining why this version is deprecated and what to upgrade to"
    }
  },
  "additionalProperties": false
}
